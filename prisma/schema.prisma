generator client {
  provider = "prisma-client-js"
  output   = "../src/__generated__/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("JAWSDB_URL")
}

model Registration {
  id                Int      @id @default(autoincrement())
  anonUserSecret    String   @unique
  zipCode           Int?
  poolAccess        Boolean?
  lastCompletedStep Int      @default(0)
  completed         Boolean  @default(false)
  formId            String

  @@map(name: "registration")
}

model RegistrationLog {
  id             Int      @id @default(autoincrement())
  timestamp      DateTime
  anonUserSecret String
  payload        String

  @@map(name: "registration_log")
}
