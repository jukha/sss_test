  @@index([start_date, end_date], map: "idx_dates")
  @@index([promo], map: "idx_promo")
  @@map("package_promo_code")
}

model UnservicedLeads {
  id        Int       @id @default(autoincrement())
  email     String    @db.VarChar(200)
  zip       String    @db.VarChar(5)
  timestamp DateTime? @db.Timestamp(0)

  @@map("unserviced_leads")
}

model FaqRecord {
  id                    Int                   @id @default(autoincrement())
  question              String                @db.VarChar(255)
  answer                String                @db.Text
  index                 Int
  faq_record_categories FaqRecordCategories[]

  @@map("faq_record")
}

model FaqCategories {
  id                    Int                   @id @default(autoincrement())
  name                  String                @db.VarChar(255)
  faq_record_categories FaqRecordCategories[]

  @@map("faq_category")
}

model FaqRecordCategories {
  id              Int @id @default(autoincrement())
  faq_record_id   Int
  faq_category_id Int

  faq_record   FaqRecord     @relation(fields: [faq_record_id], references: [id], map: "faq_record_category_ibfk_1")
  faq_category FaqCategories @relation(fields: [faq_category_id], references: [id], map: "faq_record_category_ibfk_2")

  @@index([faq_record_id], map: "faq_record_id")
  @@index([faq_category_id], map: "faq_category_id")
  @@map("faq_record_category")
}

model BlogCategories {
  id                      Int                     @id @default(autoincrement())
  name                    String                  @db.VarChar(255)
  url                     String                  @db.VarChar(255)
  icon_url                String?                 @db.VarChar(255)
  hex_color               String?                 @db.VarChar(32)
  display_order           Int
  description             String?                 @db.Text
  blog_records_categories BlogRecordsCategories[]

  @@index([display_order], map: "display_order")
  @@index([url(length: 200)], map: "url")
  @@map("blog_category")
}

model BlogRecords {
  id                             Int                     @id @default(autoincrement())
  title                          String                  @db.VarChar(255)
  featured_image                 String?                 @db.VarChar(500)
  teaser                         String?                 @db.Text
  body                           String?                 @db.Text
  author_name                    String?                 @db.VarChar(255)
  author_photo                   String?                 @db.VarChar(500)
  author_social_handle           String?                 @db.VarChar(255)
  author_social_url              String?                 @db.VarChar(500)
  created_date                   DateTime?
  publish_date                   DateTime?
  read_time                      Int?                    @db.UnsignedSmallInt
  meta_description               String?                 @db.Text
  url                            String?                 @db.VarChar(255)
  knack_submission_id            String?                 @db.VarChar(255)
  featured_image_alt_description String?                 @db.VarChar(255)
  is_featured                    Boolean?
  url_over_first                 String?                 @db.VarChar(255)
  url_over_second                String?                 @db.VarChar(255)
  url_over_third                 String?                 @db.VarChar(255)
  blog_records_categories        BlogRecordsCategories[]

  @@index([publish_date], map: "blog_publication_date")
  @@map("blog_record")
}

model BlogRecordsCategories {
  id              Int             @id @default(autoincrement())
  blog_record_id  Int
  category_id     Int
  blog_records    BlogRecords?    @relation(fields: [blog_record_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "blog_record_category_ibfk_1")
  blog_categories BlogCategories? @relation(fields: [category_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "blog_record_category_ibfk_2")

  @@index([category_id], map: "category_id")
  @@index([blog_record_id], map: "blog_record_id")
  @@map("blog_record_category")
}

model Sequence {
  id   Int    @id @default(autoincrement())
  name String @unique
  val  BigInt @default(60000)

  @@map("sequences")
}

model LocationCompetitor {
  id                          BigInt   @id @default(autoincrement())
  use_in_comparison           Boolean  @default(true)
  metro_area_id               Int
  name                        String   @db.VarChar(255)
  lesson_types                String?  @db.VarChar(191)
  address                     String?  @db.VarChar(191)
  ages                        String?  @db.VarChar(255)
  learn_to_swim_guarantee     Boolean?
  flexible_scheduling         Boolean?
  scheduling                  String?  @db.VarChar(191)
  monthly_membership_required Boolean?
  costs_per_lesson            String?  @db.VarChar(255)
  stars_count                 Decimal? @db.Decimal(2, 1)
  yelp_reviews_id             String?  @db.VarChar(255)
  google_reviews_id           String?  @db.VarChar(255)
  customer_review_text        String?  @db.Text
  lat                         Decimal? @db.Decimal(10, 7)
  lng                         Decimal? @db.Decimal(10, 7)

  @@index([metro_area_id], map: "metro_area_id")
  @@map("location_competitor")
}
