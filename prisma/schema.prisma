  off6x45    Decimal   @default(0.00) @db.Decimal(10, 2)
  free6x45   Int       @default(0) @db.UnsignedInt
  off6x60    Decimal   @default(0.00) @db.Decimal(10, 2)
  free6x60   Int       @default(0) @db.UnsignedInt
  off6x90    Decimal   @default(0.00) @db.Decimal(10, 2)
  free6x90   Int       @default(0) @db.UnsignedInt
  off6x120   Decimal   @default(0.00) @db.Decimal(10, 2)
  free6x120  Int       @default(0) @db.UnsignedInt
  off6x150   Decimal   @default(0.00) @db.Decimal(10, 2)
  free6x150  Int       @default(0) @db.UnsignedInt
  off12x30   Decimal   @default(0.00) @db.Decimal(10, 2)
  free12x30  Int       @default(0) @db.UnsignedInt
  off12x45   Decimal   @default(0.00) @db.Decimal(10, 2)
  free12x45  Int       @default(0) @db.UnsignedInt
  off12x60   Decimal   @default(0.00) @db.Decimal(10, 2)
  free12x60  Int       @default(0) @db.UnsignedInt
  off12x90   Decimal   @default(0.00) @db.Decimal(10, 2)
  free12x90  Int       @default(0) @db.UnsignedInt
  off12x120  Decimal   @default(0.00) @db.Decimal(10, 2)
  free12x120 Int       @default(0) @db.UnsignedInt
  off12x150  Decimal   @default(0.00) @db.Decimal(10, 2)
  free12x150 Int       @default(0) @db.UnsignedInt
  off18x30   Decimal   @default(0.00) @db.Decimal(10, 2)
  free18x30  Int       @default(0) @db.UnsignedInt
  off18x45   Decimal   @default(0.00) @db.Decimal(10, 2)
  free18x45  Int       @default(0) @db.UnsignedInt
  off18x60   Decimal   @default(0.00) @db.Decimal(10, 2)
  free18x60  Int       @default(0) @db.UnsignedInt
  off18x90   Decimal   @default(0.00) @db.Decimal(10, 2)
  free18x90  Int       @default(0) @db.UnsignedInt
  off18x120  Decimal   @default(0.00) @db.Decimal(10, 2)
  free18x120 Int       @default(0) @db.UnsignedInt
  off18x150  Decimal   @default(0.00) @db.Decimal(10, 2)
